<!--pages/community/community.wxml - 厕友社区-->
<view class="community-page">

  <!-- 顶部横幅 -->
  <view class="comm-hero">
    <view class="comm-hero-bg"></view>
    <view class="comm-hero-content">
      <text class="comm-title">厕友社区</text>
      <text class="comm-sub">分享你的如厕经验，帮助更多人</text>
    </view>
  </view>

  <!-- 发布动态 -->
  <view class="post-composer">
    <view class="composer-avatar">
      <text>😎</text>
    </view>
    <view class="composer-body">
      <textarea
        class="composer-input"
        placeholder="分享你的如厕经验、测评、吐槽..."
        value="{{newContent}}"
        bindinput="onComposerInput"
        maxlength="300"
        auto-height
      />
      <!-- 图片预览 -->
      <view class="composer-photos" wx:if="{{newPhotos.length}}">
        <view class="cp-item" wx:for="{{newPhotos}}" wx:key="index">
          <image class="cp-img" src="{{item}}" mode="aspectFill"></image>
          <view class="cp-del" catchtap="delPhoto" data-i="{{index}}">✕</view>
        </view>
        <view class="cp-add" wx:if="{{newPhotos.length < 3}}" bindtap="addPhoto">
          <text>＋</text>
        </view>
      </view>
      <view class="composer-footer">
        <view class="composer-tools">
          <view class="tool-btn" bindtap="addPhoto">
            <text>📷</text>
          </view>
          <text class="char-hint">{{newContent.length}}/300</text>
        </view>
        <button class="publish-btn {{newContent.trim() ? '' : 'disabled'}}" bindtap="publish">
          <text>发布</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 动态列表 -->
  <view class="feed-list">
    <view class="empty-feed" wx:if="{{posts.length === 0}}">
      <text class="empty-feed-emoji">💭</text>
      <text class="empty-feed-text">社区还很安静，来发第一条动态吧</text>
    </view>

    <view class="feed-card" wx:for="{{posts}}" wx:key="id">
      <view class="feed-header">
        <view class="feed-user">
          <view class="feed-avatar">
            <text>{{item.avatar || '🧑'}}</text>
          </view>
          <view class="feed-user-info">
            <text class="feed-name">{{item.userName}}</text>
            <text class="feed-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>

      <text class="feed-content">{{item.content}}</text>

      <!-- 图片网格 -->
      <view class="feed-photos" wx:if="{{item.photos && item.photos.length}}">
        <image
          class="feed-photo {{item.photos.length === 1 ? 'single' : ''}}"
          wx:for="{{item.photos}}"
          wx:for-item="photo"
          wx:key="index"
          src="{{photo}}"
          mode="aspectFill"
        ></image>
      </view>

      <!-- 互动栏 -->
      <view class="feed-actions">
        <view class="action-btn {{item.liked ? 'liked' : ''}}" bindtap="toggleLike" data-id="{{item.id}}">
          <text class="action-icon">{{item.liked ? '❤' : '♡'}}</text>
          <text class="action-num">{{item.likes}}</text>
        </view>
        <view class="action-btn" bindtap="commentPost" data-id="{{item.id}}">
          <text class="action-icon">💬</text>
          <text class="action-num">{{item.comments.length}}</text>
        </view>
      </view>

      <!-- 评论区 -->
      <view class="comments-section" wx:if="{{item.comments && item.comments.length}}">
        <view class="comment-item" wx:for="{{item.comments}}" wx:for-item="c" wx:key="index">
          <text class="comment-name">{{c.userName}}：</text>
          <text class="comment-text">{{c.content}}</text>
        </view>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>
