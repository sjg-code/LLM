/* pages/community/community.wxss */
.community-page { min-height: 100vh; background: #F5F6F8; }

/* 顶部横幅 */
.comm-hero { position: relative; padding: 40rpx 32rpx 48rpx; }
.comm-hero-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, #07C160, #05A34E); border-radius: 0 0 32rpx 32rpx; }
.comm-hero-content { position: relative; z-index: 1; }
.comm-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; }
.comm-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

/* 发布器 */
.post-composer { background: #fff; margin: -24rpx 24rpx 0; border-radius: 20rpx; padding: 24rpx; display: flex; gap: 16rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); position: relative; z-index: 2; }
.composer-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #E8F8EE; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.composer-body { flex: 1; }
.composer-input { width: 100%; min-height: 60rpx; font-size: 28rpx; color: #333; line-height: 1.6; border: none; padding: 0; box-sizing: border-box; }
.composer-photos { display: flex; gap: 12rpx; margin-top: 12rpx; flex-wrap: wrap; }
.cp-item { position: relative; width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; }
.cp-img { width: 100%; height: 100%; }
.cp-del { position: absolute; top: 0; right: 0; width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.5); color: #fff; font-size: 20rpx; display: flex; align-items: center; justify-content: center; border-radius: 0 0 0 12rpx; }
.cp-add { width: 160rpx; height: 160rpx; border: 2rpx dashed #D9D9D9; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #CCC; }
.composer-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #F0F0F0; }
.composer-tools { display: flex; align-items: center; gap: 16rpx; }
.tool-btn { padding: 8rpx; }
.tool-btn text { font-size: 32rpx; }
.char-hint { font-size: 22rpx; color: #CCC; }
.publish-btn { background: linear-gradient(135deg, #07C160, #06AD56); color: #fff; font-size: 26rpx; padding: 10rpx 28rpx; border-radius: 24rpx; border: none; line-height: normal; }
.publish-btn::after { border: none; }
.publish-btn.disabled { background: #D9D9D9; }

/* 动态列表 */
.feed-list { padding: 24rpx; }

/* 空状态 */
.empty-feed { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.empty-feed-emoji { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-feed-text { font-size: 26rpx; color: #999; }

/* 动态卡片 */
.feed-card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.feed-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.feed-user { display: flex; align-items: center; gap: 12rpx; }
.feed-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #E8F8EE; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.feed-user-info { display: flex; flex-direction: column; }
.feed-name { font-size: 28rpx; color: #333; font-weight: 600; }
.feed-time { font-size: 22rpx; color: #CCC; margin-top: 2rpx; }
.feed-content { font-size: 28rpx; color: #333; line-height: 1.7; display: block; margin-bottom: 16rpx; word-break: break-all; }

/* 图片网格 */
.feed-photos { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; border-radius: 12rpx; overflow: hidden; }
.feed-photo { width: 216rpx; height: 216rpx; }
.feed-photo.single { width: 400rpx; height: 300rpx; }

/* 互动栏 */
.feed-actions { display: flex; gap: 32rpx; padding-top: 12rpx; border-top: 1rpx solid #F5F5F5; }
.action-btn { display: flex; align-items: center; gap: 8rpx; padding: 4rpx 0; }
.action-icon { font-size: 28rpx; color: #999; }
.action-btn.liked .action-icon { color: #FF4D4F; }
.action-num { font-size: 24rpx; color: #999; }
.action-btn.liked .action-num { color: #FF4D4F; }

/* 评论区 */
.comments-section { margin-top: 12rpx; padding: 16rpx; background: #F9FAFB; border-radius: 12rpx; }
.comment-item { padding: 6rpx 0; }
.comment-name { font-size: 24rpx; color: #07C160; font-weight: 500; }
.comment-text { font-size: 24rpx; color: #666; }
