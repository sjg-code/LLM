/* pages/detail/detail.wxss - 现代详情页 */

.detail-page {
  min-height: 100vh;
  background: #F5F6F8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 顶部地图 ========== */
.detail-hero {
  position: relative;
  width: 100%;
  height: 440rpx;
}

.detail-map {
  width: 100%;
  height: 100%;
}

.hero-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(0deg, #F5F6F8 0%, transparent 100%);
}

/* ========== 主信息卡片 ========== */
.main-card {
  background: #fff;
  border-radius: 28rpx;
  margin: -40rpx 24rpx 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 10;
}

.main-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.main-title-wrap {
  flex: 1;
  min-width: 0;
}

.main-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.main-type-tag {
  display: inline-flex;
  padding: 6rpx 18rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.main-distance {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #E8F8EE;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  margin-left: 20rpx;
}

.dist-number {
  font-size: 34rpx;
  font-weight: 700;
  color: #07C160;
}

.dist-direction {
  font-size: 22rpx;
  color: #66BB6A;
  margin-top: 4rpx;
}

/* 评分 */
.rating-section {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.rating-stars {
  display: flex;
  gap: 4rpx;
  margin-right: 16rpx;
}

.star-icon {
  font-size: 32rpx;
  color: #E0E0E0;
  transition: color 0.2s;
}

.star-icon.filled {
  color: #FFB800;
}

.rating-score {
  font-size: 28rpx;
  color: #FFB800;
  font-weight: 600;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info-icon-wrap.green { background: #E8F8EE; }
.info-icon-wrap.blue { background: #E8F0FE; }
.info-icon-wrap.orange { background: #FFF3E0; }

.info-emoji {
  font-size: 32rpx;
}

.info-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ========== 设施卡片 ========== */
.facility-card {
  background: #fff;
  border-radius: 28rpx;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 28rpx;
}

.facility-grid {
  display: flex;
  justify-content: space-around;
}

.facility-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  padding: 24rpx 0;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.facility-box.active {
  background: #F0FAF4;
}

.facility-box.inactive {
  opacity: 0.5;
}

.fac-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.fac-circle.green {
  background: #E8F8EE;
}

.fac-circle.gray {
  background: #F5F5F5;
}

.fac-emoji {
  font-size: 36rpx;
}

.fac-name {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.fac-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.fac-badge.yes {
  background: #E8F8EE;
  color: #07C160;
}

.fac-badge.no {
  background: #FFF0F0;
  color: #FF4D4F;
}

/* ========== 标签卡片 ========== */
.tags-card {
  background: #fff;
  border-radius: 28rpx;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.tags-flow {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-pill {
  padding: 10rpx 28rpx;
  background: #E8F8EE;
  color: #07C160;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 30rpx;
  transition: all 0.2s;
}

.tag-pill:active {
  background: #D0F0DA;
}

/* ========== 底部操作栏 ========== */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.btn-nav {
  flex: 2;
  height: 92rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.3);
}

.btn-nav::after { border: none; }

.btn-share {
  flex: 1;
  height: 92rpx;
  background: #fff;
  color: #07C160;
  border: 2rpx solid #07C160;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.btn-share::after { border: none; }

.btn-nav-icon, .btn-share-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}
