/* pages/index/index.wxss - 现代卡片式设计 */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6F8;
}

/* ========== Hero 地图区 ========== */
.hero-section {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.hero-map {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 60rpx 32rpx 24rpx;
  background: linear-gradient(180deg, rgba(7,193,96,0.85) 0%, rgba(7,193,96,0.4) 60%, transparent 100%);
  z-index: 10;
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-title {
  display: flex;
  flex-direction: column;
}

.title-main {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

.relocate-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.relocate-icon {
  font-size: 36rpx;
  color: #fff;
}

/* 统计条 */
.hero-stats-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 72rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 10;
  border-radius: 24rpx 24rpx 0 0;
}

.stats-left {
  display: flex;
  align-items: center;
}

.stats-dot {
  width: 16rpx;
  height: 16rpx;
  background: #07C160;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 0 8rpx rgba(7,193,96,0.4);
}

.stats-text {
  font-size: 26rpx;
  color: #666;
}

.stats-num {
  color: #07C160;
  font-weight: 700;
  font-size: 30rpx;
}

.stats-right {
  display: flex;
  align-items: center;
}

.stats-map-text {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.stats-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #999;
  border-bottom: 3rpx solid #999;
  transition: transform 0.3s;
}

.arrow-down { transform: rotate(45deg); }
.arrow-up { transform: rotate(-135deg); }

/* ========== 分类筛选栏 ========== */
.filter-bar {
  width: 100%;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  white-space: nowrap;
}

.filter-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  background: #F5F6F8;
  transition: all 0.25s ease;
  flex-shrink: 0;
}

.filter-item.active {
  background: linear-gradient(135deg, #07C160, #06AD56);
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}

.filter-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.filter-item.active .filter-icon {
  filter: brightness(10);
}

.filter-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.filter-item.active .filter-text {
  color: #fff;
}

/* ========== 列表区 ========== */
.list-section {
  flex: 1;
  padding: 20rpx 0;
}

/* ========== 厕所卡片 ========== */
.toilet-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.card-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

/* 卡片头部 */
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-num {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.card-distance-badge {
  display: flex;
  align-items: center;
  background: #E8F8EE;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  gap: 8rpx;
}

.dist-val {
  font-size: 26rpx;
  color: #07C160;
  font-weight: 600;
}

.dist-dir {
  font-size: 22rpx;
  color: #66BB6A;
}

/* 卡片主体 */
.card-body {
  margin-bottom: 16rpx;
}

.card-info {
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 10rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

/* 标签 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.card-tag {
  display: inline-flex;
  padding: 6rpx 16rpx;
  background: #E8F8EE;
  color: #07C160;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 8rpx;
}

/* 卡片底部 */
.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.card-facilities {
  display: flex;
  gap: 24rpx;
}

.facility {
  display: flex;
  align-items: center;
  gap: 6rpx;
  opacity: 0.4;
  transition: opacity 0.2s;
}

.facility.on {
  opacity: 1;
}

.fac-icon {
  font-size: 28rpx;
}

.fac-label {
  font-size: 22rpx;
  color: #666;
}

.facility.on .fac-label {
  color: #07C160;
  font-weight: 500;
}

.card-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5F6F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 36rpx;
  color: #999;
  font-weight: 300;
}

/* 评分条 */
.card-rating {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.rating-bar-bg {
  flex: 1;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.rating-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #06AD56);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.rating-num {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 600;
  min-width: 48rpx;
  text-align: right;
}

/* ========== 加载状态 ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #07C160;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }
.dot3 { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 空状态 ========== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E8F8EE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-emoji {
  font-size: 64rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* ========== 悬浮定位按钮 ========== */
.fab-relocate {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  z-index: 100;
}

.fab-icon {
  font-size: 36rpx;
}

/* ========== 悬浮上报按钮 ========== */
.fab-upload {
  position: fixed;
  right: 32rpx;
  bottom: 320rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #06AD56);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.fab-upload-icon {
  font-size: 32rpx;
  color: #fff;
  line-height: 1;
}

.fab-upload-text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
}
