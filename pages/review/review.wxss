/* pages/review/review.wxss */
.review-page { min-height: 100vh; background: #F5F6F8; }

/* 顶部横幅 */
.hero-banner { position: relative; padding: 40rpx 32rpx 32rpx; }
.banner-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, #07C160, #05A34E); border-radius: 0 0 32rpx 32rpx; }
.banner-content { position: relative; z-index: 1; }
.banner-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.banner-desc { display: block; font-size: 26rpx; color: rgba(255,255,255,0.8); margin-bottom: 32rpx; }
.banner-stats { display: flex; align-items: center; background: rgba(255,255,255,0.2); border-radius: 20rpx; padding: 24rpx 0; }
.b-stat { flex: 1; display: flex; flex-direction: column; align-items: center; }
.b-num { font-size: 40rpx; font-weight: 700; color: #fff; }
.b-label { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }
.b-divider { width: 2rpx; height: 48rpx; background: rgba(255,255,255,0.3); }

/* Tab 切换 */
.tab-bar { display: flex; background: #fff; padding: 0 32rpx; margin-top: 16rpx; border-radius: 16rpx 16rpx 0 0; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; position: relative; transition: all 0.2s; }
.tab-item.active { color: #07C160; font-weight: 600; }
.tab-line { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 48rpx; height: 6rpx; border-radius: 3rpx; background: #07C160; }

/* 列表容器 */
.list-wrap { background: #fff; min-height: 400rpx; padding: 0 24rpx; }

/* 空状态 */
.empty-hint { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-emoji-big { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-hint text { font-size: 28rpx; color: #999; }
.empty-sub { font-size: 24rpx; color: #CCC; margin-top: 8rpx; }

/* 排行榜卡片 */
.rank-card { display: flex; align-items: center; padding: 28rpx 16rpx; border-bottom: 1rpx solid #F0F0F0; }
.rank-card:active { background: #F9F9F9; }
.rank-medal { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0; }
.rank-num { font-size: 32rpx; font-weight: 700; color: #999; }
.rank-info { flex: 1; margin-left: 16rpx; }
.rank-name { font-size: 30rpx; font-weight: 600; color: #1A1A1A; display: block; margin-bottom: 8rpx; }
.rank-meta { display: flex; align-items: center; gap: 12rpx; }
.rank-stars { font-size: 24rpx; color: #FFB800; }
.rank-avg { font-size: 26rpx; color: #FF6B00; font-weight: 600; }
.rank-count { font-size: 22rpx; color: #999; }
.rank-arrow { font-size: 36rpx; color: #CCC; }

/* 点评卡片 */
.review-card { background: #fff; padding: 28rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.rv-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.rv-user { display: flex; align-items: center; gap: 12rpx; }
.rv-avatar-wrap { width: 56rpx; height: 56rpx; border-radius: 50%; background: #E8F8EE; display: flex; align-items: center; justify-content: center; }
.rv-avatar { font-size: 28rpx; }
.rv-name { font-size: 26rpx; color: #333; font-weight: 500; }
.rv-toilet-name { font-size: 28rpx; color: #333; font-weight: 600; }
.rv-rating { display: flex; align-items: center; }
.rv-stars { font-size: 28rpx; color: #FFB800; }
.rv-content { font-size: 28rpx; color: #333; line-height: 1.6; display: block; margin-bottom: 16rpx; }
.rv-footer { display: flex; align-items: center; justify-content: space-between; }
.rv-time { font-size: 22rpx; color: #CCC; }
.rv-toilet-tag { padding: 6rpx 16rpx; background: #F5F6F8; border-radius: 16rpx; }
.rv-toilet-tag text { font-size: 22rpx; color: #666; }
