<!--pages/upload/upload.wxml - 上报厕所-->
<view class="upload-page">

  <!-- ===== 顶部提示 ===== -->
  <view class="tip-banner">
    <text class="tip-icon">💡</text>
    <text class="tip-text">发现地图上没有的厕所？帮助大家一起完善吧！</text>
  </view>

  <!-- ===== 基础信息卡片 ===== -->
  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">基础信息</text>
      <text class="card-required">* 为必填项</text>
    </view>

    <!-- 厕所名称 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">厕所名称</text>
        <text class="label-required">*</text>
      </view>
      <input
        class="form-input"
        placeholder="例如：XX公园公厕、XX商场卫生间"
        value="{{form.name}}"
        bindinput="onNameInput"
        maxlength="30"
      />
      <text class="char-count">{{form.name.length}}/30</text>
    </view>

    <!-- 详细地址 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">详细地址</text>
      </view>
      <input
        class="form-input"
        placeholder="可选，例如：公园南门入口左转50米"
        value="{{form.address}}"
        bindinput="onAddressInput"
        maxlength="60"
      />
    </view>

    <!-- 开放时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">开放时间</text>
      </view>
      <view class="time-row">
        <picker
          class="time-picker"
          mode="selector"
          range="{{timeOptions}}"
          value="{{openTimeIndex}}"
          bindchange="onOpenTimeChange"
        >
          <view class="picker-value {{openTimeIndex >= 0 ? '' : 'placeholder'}}">
            {{openTimeIndex >= 0 ? timeOptions[openTimeIndex] : '选择开始时间'}}
          </view>
        </picker>
        <text class="time-sep">至</text>
        <picker
          class="time-picker"
          mode="selector"
          range="{{timeOptions}}"
          value="{{closeTimeIndex}}"
          bindchange="onCloseTimeChange"
        >
          <view class="picker-value {{closeTimeIndex >= 0 ? '' : 'placeholder'}}">
            {{closeTimeIndex >= 0 ? timeOptions[closeTimeIndex] : '选择结束时间'}}
          </view>
        </picker>
      </view>
      <view class="allday-row" bindtap="toggleAllDay">
        <view class="checkbox {{isAllDay ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{isAllDay}}">✓</text>
        </view>
        <text class="allday-text">24小时全天开放</text>
      </view>
    </view>
  </view>

  <!-- ===== 位置选择卡片 ===== -->
  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">位置信息</text>
      <text class="card-required">*</text>
    </view>

    <!-- 定位方式 -->
    <view class="location-methods">
      <view class="method-btn {{locationMethod === 'auto' ? 'active' : ''}}" bindtap="setLocationMethod" data-method="auto">
        <text class="method-icon">📍</text>
        <text>当前位置</text>
      </view>
      <view class="method-btn {{locationMethod === 'map' ? 'active' : ''}}" bindtap="setLocationMethod" data-method="map">
        <text class="method-icon">🗺</text>
        <text>地图选点</text>
      </view>
    </view>

    <!-- 当前位置显示 -->
    <view class="location-info" wx:if="{{locationMethod === 'auto'}}">
      <view class="location-status {{locationReady ? 'success' : 'pending'}}">
        <text class="status-dot"></text>
        <text class="status-text">{{locationReady ? '已获取当前位置' : '正在获取位置...'}}</text>
      </view>
      <view class="location-retry" wx:if="{{!locationReady}}" bindtap="retryLocation">
        <text>重新定位</text>
      </view>
    </view>

    <!-- 地图选点 -->
    <view class="map-picker" wx:if="{{locationMethod === 'map'}}">
      <map
        id="uploadMap"
        class="picker-map"
        latitude="{{latitude}}"
        longitude="{{longitude}}"
        scale="16"
        markers="{{mapMarkers}}"
        show-location
        enable-zoom
        enable-scroll
        bindtap="onMapTap"
      ></map>
      <view class="map-tip" wx:if="{{!mapSelected}}">
        <text>点击地图选择厕所位置</text>
      </view>
      <view class="map-selected" wx:else>
        <text class="selected-text">✅ 已选择位置 ({{latitude.toFixed(4)}}, {{longitude.toFixed(4)}})</text>
        <view class="reselect-btn" bindtap="clearMapPoint">
          <text>重新选择</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 设施标签卡片 ===== -->
  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">设施情况</text>
    </view>
    <view class="facility-tags">
      <view
        class="facility-tag {{form.facilities[item.key] ? 'selected' : ''}}"
        wx:for="{{facilityOptions}}"
        wx:key="key"
        bindtap="toggleFacility"
        data-key="{{item.key}}"
      >
        <text class="fac-tag-icon">{{item.icon}}</text>
        <text class="fac-tag-text">{{item.label}}</text>
        <text class="fac-check" wx:if="{{form.facilities[item.key]}}">✓</text>
      </view>
    </view>
  </view>

  <!-- ===== 图片上传卡片 ===== -->
  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">现场照片</text>
      <text class="card-sub">最多5张</text>
    </view>
    <view class="photo-grid">
      <view class="photo-item" wx:for="{{photos}}" wx:key="index">
        <image class="photo-img" src="{{item}}" mode="aspectFill"></image>
        <view class="photo-delete" catchtap="deletePhoto" data-index="{{index}}">
          <text class="delete-icon">✕</text>
        </view>
      </view>
      <view class="photo-add" wx:if="{{photos.length < 5}}" bindtap="choosePhoto">
        <text class="add-icon">＋</text>
        <text class="add-text">添加照片</text>
      </view>
    </view>
  </view>

  <!-- ===== 备注卡片 ===== -->
  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">补充说明</text>
    </view>
    <textarea
      class="form-textarea"
      placeholder="可选，例如：需要找保安拿钥匙、女厕在二楼..."
      value="{{form.remark}}"
      bindinput="onRemarkInput"
      maxlength="200"
      auto-height
    />
    <text class="char-count remark-count">{{form.remark.length}}/200</text>
  </view>

  <!-- ===== 提交按钮 ===== -->
  <view class="submit-section">
    <button
      class="submit-btn {{canSubmit ? '' : 'disabled'}}"
      bindtap="submitForm"
      disabled="{{submitting}}"
    >
      <text wx:if="{{submitting}}">提交中...</text>
      <text wx:elif="{{canSubmit}}">提交上报</text>
      <text wx:else>请填写厕所名称和位置</text>
    </button>
    <text class="submit-tip">提交后我们将尽快审核，感谢您的贡献！</text>
  </view>

  <view style="height: 60rpx;"></view>
</view>
