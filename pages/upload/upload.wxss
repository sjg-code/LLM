/* pages/upload/upload.wxss */

.upload-page {
  min-height: 100vh;
  background: #F5F6F8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 顶部提示 ========== */
.tip-banner {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #E8F8EE;
  gap: 12rpx;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #07C160;
  line-height: 1.5;
}

/* ========== 表单卡片 ========== */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx 24rpx 0;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.card-required {
  font-size: 22rpx;
  color: #999;
}

.card-sub {
  font-size: 24rpx;
  color: #999;
}

/* ========== 表单项 ========== */
.form-item {
  margin-bottom: 28rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.label-required {
  color: #FF4D4F;
  margin-left: 4rpx;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.form-input:focus {
  border-color: #07C160;
  background: #fff;
}

.char-count {
  position: absolute;
  right: 16rpx;
  bottom: -28rpx;
  font-size: 22rpx;
  color: #CCC;
}

/* ========== 时间选择 ========== */
.time-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.picker-value.placeholder {
  color: #C0C0C0;
}

.time-sep {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.allday-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #D9D9D9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #07C160;
  border-color: #07C160;
}

.check-icon {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.allday-text {
  font-size: 26rpx;
  color: #666;
}

/* ========== 位置选择 ========== */
.location-methods {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.method-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.method-btn.active {
  background: #E8F8EE;
  border-color: #07C160;
}

.method-icon {
  font-size: 32rpx;
}

.method-btn text {
  font-size: 26rpx;
  color: #666;
}

.method-btn.active text {
  color: #07C160;
  font-weight: 500;
}

.location-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.location-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #CCC;
}

.location-status.success .status-dot {
  background: #07C160;
  box-shadow: 0 0 8rpx rgba(7, 193, 96, 0.4);
}

.status-text {
  font-size: 26rpx;
  color: #666;
}

.location-status.success .status-text {
  color: #07C160;
}

.location-retry {
  padding: 8rpx 20rpx;
  background: #F7F8FA;
  border-radius: 20rpx;
}

.location-retry text {
  font-size: 24rpx;
  color: #07C160;
}

/* 地图选点 */
.map-picker {
  border-radius: 16rpx;
  overflow: hidden;
}

.picker-map {
  width: 100%;
  height: 360rpx;
}

.map-tip {
  text-align: center;
  padding: 16rpx;
  background: #F7F8FA;
}

.map-tip text {
  font-size: 24rpx;
  color: #999;
}

.map-selected {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #E8F8EE;
}

.selected-text {
  font-size: 24rpx;
  color: #07C160;
}

.reselect-btn {
  padding: 6rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
}

.reselect-btn text {
  font-size: 22rpx;
  color: #07C160;
}

/* ========== 设施标签 ========== */
.facility-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.facility-tag {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F7F8FA;
  border-radius: 40rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  gap: 8rpx;
}

.facility-tag.selected {
  background: #E8F8EE;
  border-color: #07C160;
}

.fac-tag-icon {
  font-size: 28rpx;
}

.fac-tag-text {
  font-size: 26rpx;
  color: #666;
}

.facility-tag.selected .fac-tag-text {
  color: #07C160;
  font-weight: 500;
}

.fac-check {
  font-size: 22rpx;
  color: #07C160;
  font-weight: 700;
}

/* ========== 图片上传 ========== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 16rpx;
}

.delete-icon {
  color: #fff;
  font-size: 24rpx;
}

.photo-add {
  width: 180rpx;
  height: 180rpx;
  border: 3rpx dashed #D9D9D9;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
  transition: all 0.2s;
}

.photo-add:active {
  border-color: #07C160;
  background: #E8F8EE;
}

.add-icon {
  font-size: 48rpx;
  color: #CCC;
  margin-bottom: 4rpx;
}

.photo-add:active .add-icon {
  color: #07C160;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

/* ========== 备注 ========== */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
  border: 2rpx solid transparent;
}

.form-textarea:focus {
  border-color: #07C160;
  background: #fff;
}

.remark-count {
  text-align: right;
  margin-top: 8rpx;
  position: static;
}

/* ========== 提交按钮 ========== */
.submit-section {
  margin: 40rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  box-shadow: 0 8rpx 28rpx rgba(7, 193, 96, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #D9D9D9;
  box-shadow: none;
}

.submit-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}
