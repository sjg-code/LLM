/* pages/sos/sos.wxss */
.sos-page { min-height: 100vh; background: #F5F6F8; }

/* 顶部横幅 */
.sos-hero { position: relative; padding: 40rpx 32rpx 32rpx; }
.sos-hero-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, #FF6B35, #FF4444); border-radius: 0 0 32rpx 32rpx; }
.sos-hero-content { position: relative; z-index: 1; }
.sos-title-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.sos-emoji { font-size: 56rpx; }
.sos-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; }
.sos-sub { display: block; font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }
.sos-stats-row { display: flex; gap: 32rpx; }
.sos-stat { display: flex; align-items: center; gap: 8rpx; }
.sos-stat-num { font-size: 36rpx; font-weight: 700; color: #fff; }
.sos-stat-label { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* 发布卡片 */
.sos-post-card { background: #fff; margin: -16rpx 24rpx 0; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); position: relative; z-index: 2; }
.sos-input { width: 100%; min-height: 80rpx; font-size: 28rpx; color: #333; line-height: 1.6; border: none; padding: 0; box-sizing: border-box; }
.sos-post-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #F0F0F0; }
.sos-char-count { font-size: 22rpx; color: #CCC; }
.sos-post-btn { background: linear-gradient(135deg, #07C160, #06AD56); color: #fff; font-size: 26rpx; padding: 12rpx 32rpx; border-radius: 28rpx; border: none; line-height: normal; }
.sos-post-btn::after { border: none; }
.sos-post-btn.disabled { background: #D9D9D9; }

/* 区域标题 */
.sos-section-title { display: flex; align-items: center; gap: 8rpx; padding: 24rpx 32rpx 12rpx; font-size: 28rpx; color: #333; font-weight: 600; }
.section-icon { font-size: 28rpx; }

/* 列表 */
.sos-list { padding: 0 24rpx; }

/* 空状态 */
.empty-sos { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.empty-sos-emoji { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-sos-text { font-size: 26rpx; color: #999; }

/* 求助卡片 */
.sos-card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.sos-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.sos-user { display: flex; align-items: center; gap: 12rpx; }
.sos-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: #FFF3E0; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.sos-name { font-size: 26rpx; color: #333; font-weight: 500; }
.sos-time-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.sos-time { font-size: 22rpx; color: #CCC; }
.sos-expire { font-size: 20rpx; color: #FF6B35; background: #FFF3E0; padding: 2rpx 12rpx; border-radius: 12rpx; }
.sos-content { font-size: 28rpx; color: #333; line-height: 1.6; display: block; margin-bottom: 16rpx; }
.sos-card-footer { display: flex; align-items: center; justify-content: space-between; }
.sos-location { display: flex; align-items: center; gap: 6rpx; }
.sos-loc-icon { font-size: 22rpx; }
.sos-loc-text { font-size: 22rpx; color: #999; }
.sos-actions { display: flex; gap: 12rpx; }
.sos-reply-btn { padding: 8rpx 20rpx; background: #E8F8EE; border-radius: 20rpx; }
.sos-reply-btn text { font-size: 22rpx; color: #07C160; }
.sos-resolved-btn { padding: 8rpx 20rpx; background: #F5F6F8; border-radius: 20rpx; }
.sos-resolved-btn text { font-size: 22rpx; color: #999; }
.sos-resolved-btn.done { background: #E8F8EE; }
.sos-resolved-btn.done text { color: #07C160; }

/* 回复列表 */
.sos-replies { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #F0F0F0; }
.reply-item { padding: 8rpx 0; }
.reply-name { font-size: 24rpx; color: #07C160; font-weight: 500; }
.reply-text { font-size: 24rpx; color: #666; }
