<!--pages/profile/profile.wxml - 个人中心-->
<view class="profile-page">

  <!-- ===== 顶部背景 + 用户信息 ===== -->
  <view class="profile-hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <view class="avatar-wrap">
        <block wx:if="{{userAvatar}}">
          <image
            class="avatar"
            src="{{userAvatar}}"
            mode="aspectFill"
            bindtap="changeAvatar"
          ></image>
        </block>
        <view wx:else class="avatar-placeholder-wrap" bindtap="changeAvatar">
          <text class="avatar-placeholder-icon">+</text>
        </view>
        <view class="avatar-ring"></view>
        <view class="avatar-badge">
          <text class="badge-text">V1</text>
        </view>
      </view>
      <view class="user-info">
        <text class="user-name">{{userName || '微信用户'}}</text>
        <text class="user-id">ID: LM10086</text>
      </view>
      <view class="edit-btn" bindtap="editProfile">
        <text>编辑资料</text>
      </view>
    </view>
  </view>

  <!-- ===== 数据统计 ===== -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalVisits}}</text>
      <text class="stat-label">查找次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.totalNav}}</text>
      <text class="stat-label">导航次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.totalShare}}</text>
      <text class="stat-label">分享次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onQuickTap" data-key="mall">
      <text class="stat-num">{{myPoints}}</text>
      <text class="stat-label">积分</text>
    </view>
  </view>

  <!-- ===== 快捷功能 ===== -->
  <view class="quick-card">
    <text class="card-title">快捷功能</text>
    <view class="quick-grid">
      <view class="quick-item" wx:for="{{quickMenus}}" wx:key="key" bindtap="onQuickTap" data-key="{{item.key}}">
        <view class="quick-icon-wrap {{item.color}}">
          <text class="quick-emoji">{{item.icon}}</text>
        </view>
        <text class="quick-text">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 成就徽章 ===== -->
  <view class="achievement-card">
    <view class="card-title-row">
      <text class="card-title">我的成就</text>
      <text class="card-more" bindtap="viewAchievements">查看全部 ›</text>
    </view>
    <view class="achievement-list">
      <view class="achievement-item" wx:for="{{achievements}}" wx:key="id">
        <view class="achieve-icon-wrap">
          <text class="achieve-emoji">{{item.icon}}</text>
        </view>
        <view class="achieve-info">
          <text class="achieve-name">{{item.name}}</text>
          <text class="achieve-desc">{{item.desc}}</text>
        </view>
        <view class="achieve-status {{item.unlocked ? 'unlocked' : 'locked'}}">
          <text>{{item.unlocked ? '已解锁' : '未解锁'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 设置列表 ===== -->
  <view class="settings-card">
    <view class="setting-item" wx:for="{{settings}}" wx:key="key" bindtap="onSettingTap" data-key="{{item.key}}">
      <view class="setting-left">
        <text class="setting-emoji">{{item.icon}}</text>
        <text class="setting-text">{{item.label}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value" wx:if="{{item.value}}">{{item.value}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">拉了么 v1.0.0</text>
  </view>

  <view style="height: 40rpx;"></view>

  <!-- ===== 授权面板（底部弹出） ===== -->
  <view class="auth-sheet-mask" wx:if="{{showSheet}}" bindtap="hideAuthSheet" catchtouchmove="preventTouchMove"></view>
  <view class="auth-sheet {{showSheet ? 'show' : ''}}">
    <!-- 头部标题 -->
    <view class="sheet-header">
      <text class="sheet-title">授权登录</text>
      <view class="sheet-close" bindtap="hideAuthSheet">
        <text>×</text>
      </view>
    </view>

    <!-- 用户信息展示区 -->
    <view class="sheet-content">
      <view class="auth-tip">
        <text class="tip-icon">👋</text>
        <text class="tip-text">完善个人信息，获得更好的使用体验</text>
      </view>

      <!-- 头像 + 昵称组合卡片 -->
      <view class="user-info-card">
        <!-- 头像区域 -->
        <button 
          class="avatar-btn" 
          open-type="chooseAvatar" 
          bindchooseavatar="onChooseAvatar"
        >
          <view class="avatar-container {{userAvatar ? 'has-avatar' : 'no-avatar'}}">
            <block wx:if="{{userAvatar}}">
              <image 
                class="avatar-img" 
                src="{{userAvatar}}" 
                mode="aspectFill"
              ></image>
              <!-- 悬浮遮罩 -->
              <view class="avatar-overlay">
                <text class="overlay-icon">📷</text>
              </view>
            </block>
            <view wx:else class="avatar-placeholder">
              <view class="placeholder-circle">
                <text class="placeholder-icon">+</text>
              </view>
            </view>
          </view>
          <view class="avatar-hint">
            <text wx:if="{{userAvatar}}">点击更换头像</text>
            <text wx:else>点击设置头像</text>
          </view>
        </button>

        <!-- 分隔线 -->
        <view class="info-divider"></view>

        <!-- 昵称区域 -->
        <view class="nickname-area">
          <text class="nickname-label">昵称</text>
          <input 
            class="nickname-input" 
            type="nickname" 
            placeholder="请输入昵称"
            value="{{userName}}"
            bindinput="onNicknameInput"
            bindblur="onNicknameInput"
          />
        </view>
      </view>

      <!-- 提交按钮 -->
      <button class="auth-btn-primary" bindtap="onSubmitUserInfo">
        <text>保存设置</text>
      </button>

      <button class="auth-btn-ghost" bindtap="useDefaultAvatar">
        <text>稍后再说</text>
      </button>

      <!-- 隐私说明 -->
      <view class="privacy-note">
        <text class="privacy-text">🔒 你的信息将被安全保护</text>
      </view>
    </view>
  </view>
</view>
