/* pages/profile/profile.wxss */

.profile-page {
  min-height: 100vh;
  background: #F5F6F8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== Hero 区域 ========== */
.profile-hero {
  position: relative;
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 50%, #059B4C 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
  padding: 40rpx 32rpx 0;
}

.avatar-wrap {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
  background: rgba(255, 255, 255, 0.9);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.avatar:active {
  transform: scale(0.95);
}

/* 未设置头像时的占位符 */
.avatar-placeholder-wrap {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
  background: rgba(255, 255, 255, 0.2);
  border: 3rpx dashed rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.avatar-placeholder-wrap:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.3);
}

.avatar-placeholder-icon {
  font-size: 56rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
}

.avatar-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
  pointer-events: none;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFB800;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #07C160;
  box-shadow: 0 4rpx 12rpx rgba(255,184,0,0.4);
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.edit-btn {
  padding: 12rpx 40rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  border-radius: 32rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.edit-btn text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* ========== 授权按钮 ========== */
.auth-btn {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
  animation: pulse 2s ease-in-out infinite;
  transition: all 0.3s ease;
}

.auth-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.auth-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.auth-text {
  font-size: 26rpx;
  color: #07C160;
  font-weight: 500;
}

/* ========== 数据统计 ========== */
.stats-card {
  background: #fff;
  border-radius: 24rpx;
  margin: -40rpx 24rpx 20rpx;
  padding: 36rpx 0;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #07C160;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0F0F0;
}

/* ========== 快捷功能 ========== */
.quick-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 24rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33%;
  margin-bottom: 24rpx;
}

.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-icon-wrap.green { background: #E8F8EE; }
.quick-icon-wrap.blue { background: #E8F0FE; }
.quick-icon-wrap.orange { background: #FFF3E0; }
.quick-icon-wrap.purple { background: #F3E8FE; }

.quick-emoji {
  font-size: 36rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #666;
}

/* ========== 成就徽章 ========== */
.achievement-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-more {
  font-size: 24rpx;
  color: #999;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 20rpx;
}

.achieve-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #E8F8EE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.achieve-emoji {
  font-size: 32rpx;
}

.achieve-info {
  flex: 1;
  min-width: 0;
}

.achieve-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.achieve-desc {
  font-size: 22rpx;
  color: #999;
}

.achieve-status {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.achieve-status.unlocked {
  background: #E8F8EE;
  color: #07C160;
}

.achieve-status.locked {
  background: #F5F5F5;
  color: #999;
}

/* ========== 设置列表 ========== */
.settings-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-emoji {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.setting-text {
  font-size: 28rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.setting-arrow {
  font-size: 32rpx;
  color: #CCC;
  font-weight: 300;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #CCC;
}

/* ========== 底部弹出授权面板 ========== */
.auth-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.auth-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.auth-sheet.show {
  transform: translateY(0);
}

/* 面板头部 */
.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.sheet-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F5;
}

.sheet-close text {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

/* 面板内容 */
.sheet-content {
  padding: 32rpx;
  overflow-y: auto;
  flex: 1;
}

/* 授权提示 */
.auth-tip {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #F0F9FF 0%, #E0F2FE 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #0284C7;
  line-height: 1.5;
}

/* 用户信息卡片 */
.user-info-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #F0F0F0;
}

/* 头像按钮 */
.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 100%;
}

.avatar-btn::after {
  border: none;
}

.avatar-container {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  position: relative;
  margin-bottom: 16rpx;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 未设置头像时的占位符 */
.avatar-container.no-avatar {
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  border: 3rpx dashed #CED4DA;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn:active .avatar-container.no-avatar {
  transform: scale(0.92);
  background: linear-gradient(135deg, #E9ECEF 0%, #DEE2E6 100%);
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: #ADB5BD;
  line-height: 1;
}

/* 已设置头像时 */
.avatar-container.has-avatar {
  border: 4rpx solid #07C160;
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.2);
}

.avatar-btn:active .avatar-container.has-avatar {
  transform: scale(0.92);
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 悬浮遮罩 */
.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 50%;
}

.avatar-btn:active .avatar-overlay {
  opacity: 1;
}

.overlay-icon {
  font-size: 48rpx;
  filter: brightness(0) invert(1);
}

.avatar-hint {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
  margin-top: 4rpx;
}

/* 分隔线 */
.info-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 32rpx 0;
}

/* 昵称区域 */
.nickname-area {
  display: flex;
  flex-direction: column;
}

.nickname-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.nickname-input:focus {
  border-color: #07C160;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

/* 主要按钮 */
.auth-btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.25);
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.auth-btn-primary::after {
  border: none;
}

.auth-btn-primary text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.auth-btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 3rpx 10rpx rgba(7, 193, 96, 0.2);
}

/* 幽灵按钮（次要） */
.auth-btn-ghost {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 24rpx;
}

.auth-btn-ghost::after {
  border: none;
}

.auth-btn-ghost text {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

.auth-btn-ghost:active {
  background: #F8F9FA;
}

/* 隐私说明 */
.privacy-note {
  text-align: center;
  padding: 16rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: #BBBBBB;
}
