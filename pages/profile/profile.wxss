/* pages/profile/profile.wxss */

.profile-page {
  min-height: 100vh;
  background: #F5F6F8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== Hero 区域 ========== */
.profile-hero {
  position: relative;
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 50%, #059B4C 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
  padding: 40rpx 32rpx 0;
}

.avatar-wrap {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  background: #E8F8EE;
}

.avatar-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
  pointer-events: none;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFB800;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #07C160;
  box-shadow: 0 4rpx 12rpx rgba(255,184,0,0.4);
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.edit-btn {
  padding: 12rpx 40rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  border-radius: 32rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.edit-btn text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* ========== 数据统计 ========== */
.stats-card {
  background: #fff;
  border-radius: 24rpx;
  margin: -40rpx 24rpx 20rpx;
  padding: 36rpx 0;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #07C160;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0F0F0;
}

/* ========== 快捷功能 ========== */
.quick-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 24rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33%;
  margin-bottom: 24rpx;
}

.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-icon-wrap.green { background: #E8F8EE; }
.quick-icon-wrap.blue { background: #E8F0FE; }
.quick-icon-wrap.orange { background: #FFF3E0; }
.quick-icon-wrap.purple { background: #F3E8FE; }

.quick-emoji {
  font-size: 36rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #666;
}

/* ========== 成就徽章 ========== */
.achievement-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-more {
  font-size: 24rpx;
  color: #999;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 20rpx;
}

.achieve-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #E8F8EE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.achieve-emoji {
  font-size: 32rpx;
}

.achieve-info {
  flex: 1;
  min-width: 0;
}

.achieve-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.achieve-desc {
  font-size: 22rpx;
  color: #999;
}

.achieve-status {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.achieve-status.unlocked {
  background: #E8F8EE;
  color: #07C160;
}

.achieve-status.locked {
  background: #F5F5F5;
  color: #999;
}

/* ========== 设置列表 ========== */
.settings-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-emoji {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.setting-text {
  font-size: 28rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.setting-arrow {
  font-size: 32rpx;
  color: #CCC;
  font-weight: 300;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #CCC;
}
