<!--pages/mall/mall.wxml - 积分商城-->
<view class="mall-page">

  <!-- 顶部积分横幅 -->
  <view class="mall-hero">
    <view class="mall-hero-bg"></view>
    <view class="mall-hero-content">
      <view class="points-display">
        <text class="points-label">我的积分</text>
        <text class="points-num">{{myPoints}}</text>
      </view>
      <view class="points-hint">
        <text>发点评、帮急友、发动态均可获得积分</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="mall-tabs">
    <view class="mall-tab {{activeTab === 'shop' ? 'active' : ''}}" bindtap="switchTab" data-tab="shop">
      <text>商品兑换</text>
      <view class="mall-tab-line" wx:if="{{activeTab === 'shop'}}"></view>
    </view>
    <view class="mall-tab {{activeTab === 'history' ? 'active' : ''}}" bindtap="switchTab" data-tab="history">
      <text>兑换记录</text>
      <view class="mall-tab-line" wx:if="{{activeTab === 'history'}}"></view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view wx:if="{{activeTab === 'shop'}}">
    <!-- 分类筛选 -->
    <scroll-view class="category-scroll" scroll-x>
      <view class="category-list">
        <view
          class="cat-tag {{activeCategory === item.key ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="key"
          bindtap="filterCategory"
          data-cat="{{item.key}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 商品网格 -->
    <view class="items-grid">
      <view class="item-card" wx:for="{{filteredItems}}" wx:key="id" bindtap="showExchange" data-id="{{item.id}}">
        <view class="item-icon-wrap">
          <text class="item-icon">{{item.icon}}</text>
        </view>
        <text class="item-name">{{item.name}}</text>
        <text class="item-desc">{{item.desc}}</text>
        <view class="item-bottom">
          <view class="item-price">
            <text class="price-num">{{item.price}}</text>
            <text class="price-unit">积分</text>
          </view>
          <text class="item-stock">剩{{item.stock}}件</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-mall" wx:if="{{filteredItems.length === 0}}">
      <text class="empty-mall-emoji">🛒</text>
      <text class="empty-mall-text">该分类暂无商品</text>
    </view>
  </view>

  <!-- 兑换记录 -->
  <view wx:if="{{activeTab === 'history'}}">
    <view class="history-list">
      <view class="empty-mall" wx:if="{{history.length === 0}}">
        <text class="empty-mall-emoji">📦</text>
        <text class="empty-mall-text">还没有兑换记录</text>
        <text class="empty-mall-sub">快去商城兑换心仪的物品吧</text>
      </view>
      <view class="history-item" wx:for="{{history}}" wx:key="id">
        <view class="history-icon-wrap">
          <text class="history-icon">{{item.itemIcon}}</text>
        </view>
        <view class="history-info">
          <text class="history-name">{{item.itemName}}</text>
          <text class="history-time">{{item.timeText}}</text>
        </view>
        <text class="history-price">-{{item.price}}积分</text>
      </view>
    </view>
  </view>

  <!-- 兑换确认弹窗 -->
  <view class="confirm-mask" wx:if="{{showConfirm}}" bindtap="cancelExchange">
    <view class="confirm-dialog" catchtap="">
      <view class="confirm-header">
        <text class="confirm-title">确认兑换</text>
      </view>
      <view class="confirm-body">
        <view class="confirm-item-icon">
          <text>{{confirmItem.icon}}</text>
        </view>
        <text class="confirm-item-name">{{confirmItem.name}}</text>
        <text class="confirm-item-price">需要 {{confirmItem.price}} 积分</text>
        <text class="confirm-balance">当前余额：{{myPoints}} 积分</text>
      </view>
      <view class="confirm-footer">
        <view class="confirm-cancel" bindtap="cancelExchange">
          <text>取消</text>
        </view>
        <view class="confirm-ok {{myPoints >= confirmItem.price ? '' : 'disabled'}}" bindtap="confirmExchange">
          <text>{{myPoints >= confirmItem.price ? '确认兑换' : '积分不足'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>
